# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_actual_openai_api_key_here

# Embucket Server Configuration
EMBUCKET_HOST=localhost
EMBUCKET_PORT=3000

# Fuzzing Configuration
SLT_OUTPUT_DIR=test/sql/fuzz_regressions
DEFAULT_COMPLEXITY=medium
DEFAULT_NUM_QUERIES=10

# Optional: Model Configuration
# OPENAI_MODEL=gpt-4
# OPENAI_MAX_TOKENS=4000

# Snowflake Configuration (for Snowflake query execution tool)
# SNOWFLAKE_ACCOUNT=your_account
# SNOWFLAKE_USER=your_username
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=your_database
# SNOWFLAKE_SCHEMA=public

# Instructions:
# 1. Copy this file to .env
# 2. Replace 'sk-your_actual_openai_api_key_here' with your actual OpenAI API key
# 3. Adjust other settings as needed
